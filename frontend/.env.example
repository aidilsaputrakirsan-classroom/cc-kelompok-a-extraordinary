# =============================================
# FRONTEND ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================
# Salin file ini ke .env lalu isi nilainya:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
#
# Variabel ini digunakan oleh Vite (harus dimulai dengan VITE_)
# Akses di kode: import.meta.env.VITE_API_URL
#
# JANGAN commit file .env ke Git!
# =============================================

# --- API Configuration ---
# URL backend API (FastAPI server)
# Development: http://localhost:8000
# Production: https://your-api-domain.com
VITE_API_URL=http://localhost:8000

# --- App Settings ---
# Nama aplikasi (untuk title, header, dll)
VITE_APP_TITLE=Cloud App

# Environment (development/production/staging)
VITE_APP_ENV=development

# Debug mode (true/false) - disable di production
VITE_DEBUG=true
