# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/temuin_db

# Firebase Admin SDK (Optional, defaults to application default credentials if not set)
FIREBASE_CREDENTIALS_FILE=firebase-adminsdk.json

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
