# =============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================
# Salin file ini ke .env lalu isi nilainya:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
#
# JANGAN commit file .env ke Git!
# =============================================

# --- Database ---
# Format: postgresql+psycopg://<username>:<password>@<host>:<port>/<database>
# Untuk development lokal (non-Docker):
# DATABASE_URL=postgresql+psycopg://postgres:yourpassword@localhost:5432/cloudapp

# Untuk Docker container (akses PostgreSQL di host machine):
# DATABASE_URL=postgresql://postgres:PASSWORD_ANDA@host.docker.internal:5432/cloudapp
DATABASE_URL=postgresql://postgres:codetohero000@host.docker.internal:5432/cloudapp

# --- JWT Auth ---
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=9914a8ba2e4bde50f9fb4e33da1398801975f59c2b2c955fec1b9ba3bc6c6b65
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Pisahkan beberapa origin dengan koma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# --- App Settings ---
APP_ENV=development
DEBUG=true

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000